# Echo Bot Environment Variables
# Fill these in before running the bot!

# Your Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=

# MongoDB URI
# Required for Echo's database (counting, suggestions, etc) and Groq AI history
PostgreSQL_URI=

# Groq API Key
# Required for AI chat functionality. Get this from https://console.groq.com/
GROQ_API_KEY=

# Optional: Spotify/SoundCloud IDs for music functionality
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SOUNDCLOUD_CLIENT_ID=
